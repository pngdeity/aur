_npmname=@google/jules
_npmver=0.1.42
pkgname=jules-tools # All lowercase
pkgver=0.1.42
pkgrel=1
pkgdesc="Jules, the asynchronous coding agent from Google, in the terminal."
arch=(any)
url="https://jules.google"
license=()
depends=('nodejs' 'npm')
makedepends=('npm')
optdepends=()
source=(
  "https://registry.npmjs.org/$_npmname/-/$_npmname-$_npmver.tgz"
)
noextract=($_npmname-$_npmver.tgz)
sha1sums=(cc2a1be2ea6e6ca53b51bcccf903ccf457431fe1)

package() {
  cd $srcdir
  local _npmdir="$pkgdir/usr/lib/node_modules/"
  mkdir -p $_npmdir
  cd $_npmdir
  npm install -g --prefix "$pkgdir/usr" $_npmname@$_npmver
  chown -R root:root "$pkgdir"
}

